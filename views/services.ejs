<%- include('partials/head') %>
<%- include('partials/header') %>

<main id="main">
  <section class="container">
    <header class="page-head">
      <span class="page-head__ghost" aria-hidden="true">Prices</span>
      <p class="eyebrow">Services</p>
      <h1>Services and prices.</h1>
      <p class="page-head__lede">
        Clear prices for haircuts, skin fades, beard work and grooming add-ons.
        Choose a service, then pick a time that suits you.
      </p>
    </header>
  </section>

  <% groups.forEach(function(group){ %>
    <% if (group.items.length) { %>
      <section class="price-group" aria-labelledby="group-<%= group.id %>">
        <h2 id="group-<%= group.id %>" class="price-group__title"><%= group.label %></h2>
        <ul class="menu-list">
          <% group.items.forEach(function(s){ %>
            <li>
              <a class="menu-row" href="/book/barber?service=<%= s.slug %>">
                <h3 class="menu-row__name"><%= s.name %></h3>
                <p class="menu-row__desc"><%= s.description %></p>
                <span class="menu-row__price">£<%= s.price %></span>
              </a>
            </li>
          <% }); %>
        </ul>
      </section>
    <% } %>
  <% }); %>

  <section class="section section--contrast" aria-label="Book CTA">
    <div class="container" style="text-align: center;">
      <h2 style="max-width: 20ch; margin: 0 auto var(--s-5);">Ready for a time?</h2>
      <a class="btn btn--primary btn--lg" href="/book">Book now</a>
    </div>
  </section>
</main>

<%- include('partials/footer') %>
