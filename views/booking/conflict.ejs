<%- include('../partials/head') %>
<%- include('../partials/header') %>

<main id="main">
  <section class="container container--narrow">
    <header class="page-head">
      <p class="eyebrow">That slot is gone</p>
      <h1>Someone beat you to it.</h1>
      <p class="page-head__lede">
        <% if (barber !== 'any') { %>
          That barber just got booked for the time you picked.
        <% } else { %>
          All three barbers were just taken for that time.
        <% } %>
        Pick another one and we will hold the chair as soon as you confirm.
      </p>
    </header>
  </section>

  <section class="section section--dark">
    <div class="container container--narrow">
      <div style="display: flex; gap: var(--s-3); flex-wrap: wrap;">
        <a class="btn btn--primary" href="/book?service=<%= service.slug %>&amp;barber=<%= barber %><%= dateKey ? '&date=' + dateKey : '' %>">
          See other times
        </a>
        <a class="btn btn--ghost" href="/services">Change service</a>
      </div>
    </div>
  </section>
</main>

<%- include('../partials/footer') %>
