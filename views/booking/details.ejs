<%- include('../partials/head') %>
<%- include('../partials/header') %>

<main id="main">
  <section class="container container--narrow">
    <%- include('_step-nav', { step }) %>

    <header class="page-head">
      <div class="service-tag">
        <span class="service-tag__name"><%= service.name %></span>
        <span class="service-tag__meta"><%= slotDateLong %> · <%= slotLabel %></span>
        <a class="service-tag__change" href="/book/time?service=<%= service.slug %>&barber=<%= barberChosen %>">Change</a>
      </div>
      <h1>Your details.</h1>
      <p class="page-head__lede">We'll email your confirmation and keep your details on file for this booking only.</p>
    </header>
  </section>

  <section class="container container--narrow" style="padding-bottom: var(--s-9);">
    <form class="form" method="post" action="/book/confirm" novalidate>
      <input type="hidden" name="service" value="<%= service.slug %>">
      <input type="hidden" name="slot"    value="<%= slotIso %>">
      <input type="hidden" name="barber"  value="<%= barberChosen %>">

      <label class="field">
        <span>Full name</span>
        <input
          name="name"
          type="text"
          autocomplete="name"
          required
          value="<%= form.name %>"
          <% if (errors && errors.name) { %> aria-invalid="true" aria-describedby="err-name"<% } %>>
        <% if (errors && errors.name) { %>
          <small class="field__error" id="err-name"><%= errors.name %></small>
        <% } %>
      </label>

      <label class="field">
        <span>Email</span>
        <input
          name="email"
          type="email"
          autocomplete="email"
          inputmode="email"
          required
          value="<%= form.email %>"
          <% if (errors && errors.email) { %> aria-invalid="true" aria-describedby="err-email"<% } %>>
        <% if (errors && errors.email) { %>
          <small class="field__error" id="err-email"><%= errors.email %></small>
        <% } %>
      </label>

      <label class="field">
        <span>Mobile</span>
        <input
          name="phone"
          type="tel"
          autocomplete="tel"
          inputmode="tel"
          required
          value="<%= form.phone %>"
          <% if (errors && errors.phone) { %> aria-invalid="true" aria-describedby="err-phone"<% } %>>
        <% if (errors && errors.phone) { %>
          <small class="field__error" id="err-phone"><%= errors.phone %></small>
        <% } %>
      </label>

      <label class="field">
        <span>Anything we should know? <small>(optional)</small></span>
        <textarea name="notes" rows="3"><%= form.notes %></textarea>
      </label>

      <button class="btn btn--primary btn--lg" type="submit">Confirm booking</button>
      <p style="color: var(--ink-mute); font-size: 0.85rem; margin: 0;">
        By booking you agree we can email you the confirmation.
      </p>
    </form>
  </section>
</main>

<%- include('../partials/footer') %>
