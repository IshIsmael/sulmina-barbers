<%- include('../partials/head') %>
<%- include('../partials/header') %>

<main id="main">
  <section class="container container--narrow">
    <%- include('_step-nav', { step }) %>

    <header class="page-head">
      <h1>Your details.</h1>
      <p class="page-head__lede">We will email your confirmation and keep your details on file for this booking only.</p>
    </header>
  </section>

  <section class="section section--dark" aria-label="Confirm booking details">
    <div class="container container--narrow">
      <div class="booking-summary" aria-label="Your appointment so far">
        <div class="booking-summary__row">
          <span>Service</span>
          <strong><%= service.name %></strong>
        </div>
        <div class="booking-summary__row">
          <span>Duration &middot; price</span>
          <strong><%= service.durationMinutes %> min &middot; &pound;<%= service.price %></strong>
        </div>
        <div class="booking-summary__row">
          <span>Barber</span>
          <strong><%= barberLabel %></strong>
        </div>
        <div class="booking-summary__row">
          <span>When</span>
          <strong><%= slotDateLong %> &middot; <%= slotLabel %></strong>
        </div>
        <a class="booking-summary__change" href="/book?service=<%= service.slug %>&amp;barber=<%= barberChosen %>">Change time</a>
      </div>

      <form class="form" method="post" action="/book/confirm" novalidate>
        <input type="hidden" name="service" value="<%= service.slug %>">
        <input type="hidden" name="slot" value="<%= slotIso %>">
        <input type="hidden" name="barber" value="<%= barberChosen %>">

        <label class="field">
          <span>Full name</span>
          <input
            name="name"
            type="text"
            autocomplete="name"
            required
            value="<%= form.name %>"
            <% if (errors && errors.name) { %> aria-invalid="true" aria-describedby="err-name"<% } %>>
          <% if (errors && errors.name) { %>
            <small class="field__error" id="err-name"><%= errors.name %></small>
          <% } %>
        </label>

        <label class="field">
          <span>Email</span>
          <input
            name="email"
            type="email"
            autocomplete="email"
            inputmode="email"
            required
            value="<%= form.email %>"
            <% if (errors && errors.email) { %> aria-invalid="true" aria-describedby="err-email"<% } %>>
          <% if (errors && errors.email) { %>
            <small class="field__error" id="err-email"><%= errors.email %></small>
          <% } %>
        </label>

        <label class="field">
          <span>Mobile</span>
          <input
            name="phone"
            type="tel"
            autocomplete="tel"
            inputmode="tel"
            required
            value="<%= form.phone %>"
            <% if (errors && errors.phone) { %> aria-invalid="true" aria-describedby="err-phone"<% } %>>
          <% if (errors && errors.phone) { %>
            <small class="field__error" id="err-phone"><%= errors.phone %></small>
          <% } %>
        </label>

        <label class="field">
          <span>Anything we should know? <small>(optional)</small></span>
          <textarea name="notes" rows="3"><%= form.notes %></textarea>
        </label>

        <button class="btn btn--primary btn--lg" type="submit">Confirm booking</button>
        <p style="color: var(--text-faint); font-size: 0.85rem; margin: 0;">
          By booking you agree we can email you the confirmation.
        </p>
      </form>
    </div>
  </section>
</main>

<%- include('../partials/footer') %>
