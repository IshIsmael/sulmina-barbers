<%- include('../partials/head') %>
<%- include('../partials/header') %>

<main id="main">
  <section class="container">
    <%- include('_step-nav', { step }) %>

    <header class="page-head page-head--split">
      <div>
        <div class="service-tag">
          <span class="service-tag__name"><%= service.name %></span>
          <span class="service-tag__meta"><%= service.durationMinutes %> min &middot; &pound;<%= service.price %></span>
          <a class="service-tag__change" href="/services">Change</a>
        </div>
        <h1>Pick a time.</h1>
      </div>
      <p class="page-head__lede">
        Slots are live. Switch barber, move the week, or jump to the next open day.
      </p>
    </header>
  </section>

  <section class="section section--dark" aria-label="Choose a time">
    <div class="container">
      <%- include('_time-grid', {
        service, strip, weekStart, weekRangeLabel,
        prevWeekStart, nextWeekStart,
        dateKey, dateLong, groups, totalSlotCount,
        nextOpen, barberTabs, barberFilter, barberFilterParam,
        barberLabel: typeof barberLabel !== 'undefined' ? barberLabel : 'Any available',
        selectedSlotIso: typeof selectedSlotIso !== 'undefined' ? selectedSlotIso : null,
        selectedSlotLabel: typeof selectedSlotLabel !== 'undefined' ? selectedSlotLabel : null,
        selectedSlotDateLong: typeof selectedSlotDateLong !== 'undefined' ? selectedSlotDateLong : null,
        shop
      }) %>
    </div>
  </section>
</main>

<%- include('../partials/footer') %>
