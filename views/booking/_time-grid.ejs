<% const gridBasePath = typeof bookingBasePath !== 'undefined' ? bookingBasePath : '/book/time'; %>
<% const renderBarberTabs = typeof showBarberTabs === 'undefined' || showBarberTabs; %>
<% const activeSlotIso = typeof selectedSlotIso !== 'undefined' ? selectedSlotIso : null; %>
<div class="time-grid"
     data-service="<%= service.slug %>"
     data-barber="<%= barberFilterParam %>"
     data-date="<%= dateKey %>"
     data-week-start="<%= weekStart %>"
     data-date-long="<%= dateLong %>"
     data-barber-label="<%= typeof barberLabel !== 'undefined' ? barberLabel : 'Any available' %>"
     data-selected-slot-iso="<%= activeSlotIso || '' %>"
     data-selected-slot-label="<%= typeof selectedSlotLabel !== 'undefined' && selectedSlotLabel ? selectedSlotLabel : '' %>"
     data-selected-slot-date-long="<%= typeof selectedSlotDateLong !== 'undefined' && selectedSlotDateLong ? selectedSlotDateLong : '' %>">

  <% if (renderBarberTabs) { %>
    <nav class="barber-strip" aria-label="Choose a barber">
      <div class="barber-strip__inner" role="tablist" aria-label="Barbers">
        <% barberTabs.forEach(function(tab){ %>
          <a class="barber-tab <%= tab.isActive ? 'is-active' : '' %>"
             role="tab"
             data-tg-swap
             data-tg-query="barber=<%= tab.value %>"
             href="<%= gridBasePath %>?service=<%= service.slug %>&amp;date=<%= dateKey %>&amp;weekStart=<%= weekStart %>&amp;barber=<%= tab.value %>#booking-time"
             aria-selected="<%= tab.isActive ? 'true' : 'false' %>">
            <%= tab.label %>
          </a>
        <% }); %>
      </div>
    </nav>
  <% } %>

  <div class="week-nav" role="group" aria-label="Week navigation">
    <% if (prevWeekStart) { %>
      <a class="week-nav__btn"
         data-tg-swap
         data-tg-query="weekStart=<%= prevWeekStart %>"
         href="<%= gridBasePath %>?service=<%= service.slug %>&amp;date=<%= prevWeekStart %>&amp;weekStart=<%= prevWeekStart %>&amp;barber=<%= barberFilterParam %>#booking-time"
         aria-label="Previous week">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M15 18l-6-6 6-6" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <span class="week-nav__btn-label">Prev</span>
      </a>
    <% } else { %>
      <span class="week-nav__btn is-disabled" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M15 18l-6-6 6-6" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <span class="week-nav__btn-label">Prev</span>
      </span>
    <% } %>

    <span class="week-nav__title"><%= weekRangeLabel %></span>

    <% if (nextWeekStart) { %>
      <a class="week-nav__btn"
         data-tg-swap
         data-tg-query="weekStart=<%= nextWeekStart %>"
         href="<%= gridBasePath %>?service=<%= service.slug %>&amp;date=<%= nextWeekStart %>&amp;weekStart=<%= nextWeekStart %>&amp;barber=<%= barberFilterParam %>#booking-time"
         aria-label="Next week">
        <span class="week-nav__btn-label">Next</span>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M9 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    <% } else { %>
      <span class="week-nav__btn is-disabled" aria-hidden="true">
        <span class="week-nav__btn-label">Next</span>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M9 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </span>
    <% } %>
  </div>

  <div class="date-strip-wrap">
    <nav class="date-strip" aria-label="Choose a date">
      <% strip.forEach(function(d){ %>
        <a class="date-pill <%= d.isSelected ? 'is-selected' : '' %> <%= d.isToday ? 'is-today' : '' %>"
           data-tg-swap
           data-tg-query="date=<%= d.key %>"
           href="<%= gridBasePath %>?service=<%= service.slug %>&amp;date=<%= d.key %>&amp;weekStart=<%= weekStart %>&amp;barber=<%= barberFilterParam %>#booking-time"
           aria-current="<%= d.isSelected ? 'date' : 'false' %>">
          <span class="date-pill__weekday"><%= d.weekday %></span>
          <span class="date-pill__day"><%= d.day %></span>
        </a>
      <% }); %>
    </nav>
  </div>

  <div class="slots-region" aria-live="polite" aria-busy="false">
    <h2 class="slots-head" tabindex="-1"><%= dateLong %></h2>

    <% if (groups.length === 0 || totalSlotCount === 0) { %>
      <div class="slots-empty" role="status">
        <p class="slots-empty__title">No times available</p>
        <p class="slots-empty__body">
          <% if (barberFilter !== 'any') { %>
            That barber is fully booked on <%= dateLong %>.
            Try
            <a class="link-arrow link-arrow--inline"
               data-tg-swap
               data-tg-query="barber=any"
               href="<%= gridBasePath %>?service=<%= service.slug %>&amp;date=<%= dateKey %>&amp;weekStart=<%= weekStart %>&amp;barber=any#booking-time">any barber</a>
            or pick another day.
          <% } else { %>
            All three barbers are fully booked on <%= dateLong %>.
            Pick another day, or call the shop on <a href="<%= shop.phoneHref %>"><%= shop.phone %></a>.
          <% } %>
        </p>
        <% if (nextOpen) { %>
          <a class="btn btn--primary slots-empty__jump"
             data-tg-swap
             data-tg-query="date=<%= nextOpen.key %>&weekStart=<%= nextOpen.key %>"
             href="<%= gridBasePath %>?service=<%= service.slug %>&amp;date=<%= nextOpen.key %>&amp;weekStart=<%= nextOpen.key %>&amp;barber=<%= barberFilterParam %>#booking-time">
            Jump to <%= nextOpen.label %> <span aria-hidden="true">&rarr;</span>
          </a>
        <% } %>
      </div>
    <% } else { %>
      <% groups.forEach(function(group){ %>
        <section class="slots-section" aria-labelledby="slots-<%= group.id %>">
          <h3 class="slots-section__label" id="slots-<%= group.id %>"><%= group.label %></h3>
          <div class="slot-grid" role="list">
            <% group.items.forEach(function(s){ %>
              <% if (s.status === 'free') { %>
                <a class="slot <%= activeSlotIso === s.iso ? 'is-selected' : '' %>" role="listitem"
                   data-tg-swap
                   href="/book?service=<%= service.slug %>&amp;date=<%= dateKey %>&amp;weekStart=<%= weekStart %>&amp;barber=<%= barberFilterParam %>&amp;slot=<%= encodeURIComponent(s.iso) %>#booking-details"
                   aria-current="<%= activeSlotIso === s.iso ? 'time' : 'false' %>">
                  <%= s.label %>
                </a>
              <% } %>
            <% }); %>
          </div>
        </section>
      <% }); %>
    <% } %>
  </div>

</div>
