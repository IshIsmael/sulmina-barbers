<%- include('partials/head') %>
<%- include('partials/header') %>

<main id="main">
  <section class="container">
    <header class="page-head page-head--split">
      <div>
        <span class="page-head__ghost" aria-hidden="true">The shop</span>
        <p class="eyebrow">About</p>
        <h1>The barbershop on 43 High Street.</h1>
      </div>
      <p class="page-head__lede">
        Sulmina is a local Southgate barber shop for haircuts, skin fades, beard work
        and the regular tidy-ups that keep you feeling put together.
      </p>
    </header>
  </section>

  <section class="section section--paper" aria-labelledby="about-story">
    <div class="container">
      <div class="story">
        <div class="story__copy">
          <p class="eyebrow">The chair</p>
          <h2 id="about-story">Easy conversation, careful work.</h2>
          <p>
            We keep the shop simple: listen first, cut carefully, finish clean.
            Some people know their exact fade and length before they sit down.
            Others bring a photo, ask for advice, or just want their usual shape
            brought back in.
          </p>
          <p>
            The team covers the day-to-day services Southgate clients ask for:
            haircuts, skin fades, taper fades, beard shaping, children's cuts,
            seniors' cuts, face masks and the full service with hot towel.
          </p>

          <ul class="about-points" aria-label="Shop details">
            <li><span>Where</span><strong>43 High Street, Southgate N14</strong></li>
            <li><span>Book</span><strong>Online appointments or phone bookings</strong></li>
            <li><span>Open</span><strong>Seven days, with late evenings most days</strong></li>
          </ul>
        </div>

        <div class="story__media">
          <div class="story__photo">
            <img src="/images/gallery/02.jpg"
                 alt="A recent fade at Sulmina Barber Shop"
                 loading="lazy"
                 decoding="async">
          </div>
          <span class="story__tag">High Street N14</span>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--dark cta-band">
    <div class="container">
      <p class="eyebrow eyebrow--bare">Come in</p>
      <h2>43 High Street, Southgate.</h2>
      <p>Book online or call the shop and we will help you find a time.</p>
      <a class="btn btn--gold btn--lg" href="/services">Book now <span class="arr" aria-hidden="true">&rarr;</span></a>
      <p style="margin-top: var(--s-5);">or call <a href="<%= shop.phoneHref %>"><%= shop.phone %></a></p>
    </div>
  </section>
</main>

<%- include('partials/footer') %>
