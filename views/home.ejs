<%- include('partials/head') %>
<%- include('partials/header') %>

<main id="main">

  <section class="hero hero--white" aria-labelledby="home-title">
    <div class="hero__inner container">
      <div class="hero__layout">
        <div class="hero__copy">
          <p class="hero__script">Southgate <span>N14</span></p>
          <h1 class="hero__title" id="home-title">
            <span class="hero__word">Sulmina</span>
            <span class="hero__word">Barber</span>
            <span class="hero__word hero__word--final">Shop</span>
          </h1>
          <p class="hero__lede">
            Haircuts, skin fades and beard work at 43 High Street, Southgate.
          </p>
          <div class="hero__actions">
            <a class="btn btn--ink btn--lg" href="/services">Book a chair <span class="arr" aria-hidden="true">&rarr;</span></a>
          </div>
        </div>

        <div class="hero__media" aria-hidden="true">
          <div class="hero__cutout hero__cutout--asset">
            <img src="/images/hero-white-barber-collage.png"
                 alt=""
                 width="1536" height="1024"
                 loading="eager" decoding="async" fetchpriority="high">
          </div>
          <span class="hero__seal">Est. on the<br>High Street</span>
        </div>
      </div>

      <aside class="hero__proof hero__proof--paper" aria-label="Shop facts">
        <div class="proof-grid">
          <div class="proof-item">
            <span class="proof-item__icon" aria-hidden="true">43</span>
            <span><strong>43 High Street</strong><span>Southgate, London</span></span>
          </div>
          <div class="proof-item">
            <span class="proof-item__icon" aria-hidden="true">7</span>
            <span><strong>Open 7 days</strong><span><% if (todayHours) { %>Today <%= todayHours %><% } else { %>Late evenings most days<% } %></span></span>
          </div>
          <div class="proof-item">
            <span class="proof-item__icon" aria-hidden="true">&pound;</span>
            <span><strong>From &pound;11</strong><span>Clear prices before you book</span></span>
          </div>
        </div>
      </aside>
    </div>
  </section>

  <section class="section section--paper home-services" aria-labelledby="highlights-heading">
    <div class="container">
      <div class="section-head reveal">
        <div>
          <p class="eyebrow">Services</p>
          <h2 id="highlights-heading">Most booked services.</h2>
        </div>
        <p>
          Clear timings, live availability and no mystery pricing. These are the
          services clients book again and again.
        </p>
      </div>

      <div class="price-board reveal d1">
        <% highlights.forEach(function(s){ %>
          <a class="price-row" href="/book?service=<%= s.slug %>">
            <div class="price-row__main">
              <h3 class="price-row__name"><%= s.name %></h3>
              <p class="price-row__desc"><%= s.description %></p>
            </div>
            <div class="price-row__meta">
              <span class="price-row__price">&pound;<%= s.price %></span>
              <span class="price-row__duration"><%= s.durationMinutes %> min</span>
            </div>
            <span class="price-row__arrow" aria-hidden="true">&rarr;</span>
          </a>
        <% }); %>
      </div>

      <p style="margin: var(--s-6) 0 0; text-align: center;" class="reveal">
        <a class="btn btn--gold btn--lg" href="/services">See all services <span class="arr" aria-hidden="true">&rarr;</span></a>
      </p>
    </div>
  </section>

  <section class="section section--paper section--compact home-trust" aria-labelledby="trust-heading">
    <div class="container">
      <div class="home-trust__head reveal">
        <p class="eyebrow">The shop</p>
        <h2 id="trust-heading">Booking and shop details.</h2>
      </div>
      <div class="trust-grid reveal d1" aria-label="Sulmina shop facts">
        <div class="trust-item">
          <span>Where</span>
          <strong>43 High Street</strong>
          <p>Southgate, London N14</p>
        </div>
        <div class="trust-item">
          <span>Open</span>
          <strong>Seven days</strong>
          <p><% if (todayHours) { %>Today <%= todayHours %><% } else { %>Late evenings most days<% } %></p>
        </div>
        <div class="trust-item">
          <span>Book</span>
          <strong>Online or phone</strong>
          <p>Pick a time or call the shop.</p>
        </div>
        <div class="trust-item">
          <span>Prices</span>
          <strong>From &pound;11</strong>
          <p>Clear before you confirm.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section reviews" aria-labelledby="reviews-heading">
    <div class="container">
      <div class="section-head reveal">
        <div>
          <p class="eyebrow">From Google</p>
          <h2 id="reviews-heading">What clients say.</h2>
        </div>
        <p>Live reviews from people who sat in the chair.</p>
      </div>

      <div class="reviews__frame">
        <div class="elfsight-app-044748cb-0e56-4343-bd8c-c40f63168cc4" data-elfsight-app-lazy>
          <div class="reviews__skeleton" aria-hidden="true">
            <span>Loading reviews from Google...</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--paper section--compact home-contact" aria-label="Contact information">
    <div class="container contact-strip">
      <div class="contact-item reveal">
        <span class="contact-item__label">Call</span>
        <p class="contact-item__value">
          <a href="<%= shop.phoneHref %>" class="u-clean"><%= shop.phone %></a>
        </p>
        <a class="link-arrow" href="<%= shop.phoneHref %>">Tap to call <span aria-hidden="true">&rarr;</span></a>
      </div>

      <div class="contact-item reveal d1">
        <span class="contact-item__label">Visit</span>
        <p class="contact-item__value">43 High Street<br>London N14 6LD</p>
        <a class="link-arrow" href="https://www.google.com/maps?q=43+High+St,+London+N14+6LD" rel="noopener">Get directions <span aria-hidden="true">&rarr;</span></a>
      </div>

      <div class="contact-item reveal d2">
        <span class="contact-item__label">Hours</span>
        <ul class="hours-table">
          <% hours.forEach(function(h){ %>
            <li class="<%= typeof todayLabel !== 'undefined' && h.days === todayLabel ? 'is-today' : '' %>">
              <span><%= h.days %></span>
              <span><%= h.time %></span>
            </li>
          <% }); %>
        </ul>
      </div>
    </div>
  </section>

</main>

<%- include('partials/footer') %>
