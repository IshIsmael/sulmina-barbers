<%- include('partials/head') %>
<%- include('partials/header') %>

<main id="main">
  <section class="container">
    <header class="page-head page-head--split">
      <div>
        <span class="page-head__ghost" aria-hidden="true">The work</span>
        <p class="eyebrow">Gallery</p>
        <h1>Recent work.</h1>
      </div>
      <p class="page-head__lede">
        Finished cuts, fades, beards and shots from inside Sulmina Barber Shop.
        All photos are from the shop floor.
      </p>
    </header>
  </section>

  <section class="section section--paper" aria-label="Gallery">
    <div class="container">
      <% if (images && images.length > 0) { %>
        <div class="gallery-grid">
          <% images.forEach(function(img, i){ %>
            <figure class="gallery-tile">
              <img src="<%= img.src %>"
                   alt="Work at Sulmina Barber Shop, photo <%= i + 1 %>"
                   loading="<%= i < 2 ? 'eager' : 'lazy' %>"
                   decoding="async">
            </figure>
          <% }); %>
        </div>
      <% } else { %>
        <div class="paper-panel atelier-panel" style="max-width: 56ch;">
          <h2>Gallery is empty.</h2>
          <p>
            Add photos to <code>public/images/gallery/</code>, named
            <code>01.jpg</code>, <code>02.jpg</code> and so on.
          </p>
        </div>
      <% } %>
    </div>
  </section>
</main>

<%- include('partials/footer') %>
