<%- include('partials/head') %>
<%- include('partials/header') %>

<main id="main">
  <section class="container">
    <header class="page-head page-head--split">
      <div>
        <span class="page-head__ghost" aria-hidden="true">Find us</span>
        <p class="eyebrow">Contact</p>
        <h1>Find the shop.</h1>
      </div>
      <p class="page-head__lede">
        Sulmina Barber Shop is at 43 High Street, Southgate, London N14 6LD.
        Call ahead or book your appointment online.
      </p>
    </header>
  </section>

  <section class="section section--paper">
    <div class="container">
      <div class="contact-grid">

        <div class="contact-grid__info">
          <div class="info-row">
            <p class="eyebrow">Address</p>
            <p class="info-row__value">43 High Street<br>London N14 6LD</p>
            <a class="link-arrow" href="https://www.google.com/maps?q=Sulmina+Barber+Shop,+43+High+St,+Southgate,+London+N14+6LD" rel="noopener">Open in Maps <span aria-hidden="true">&rarr;</span></a>
          </div>

          <div class="info-row">
            <p class="eyebrow">Phone</p>
            <p class="info-row__value info-row__value--lg">
              <a href="<%= shop.phoneHref %>" class="u-clean"><%= shop.phone %></a>
            </p>
            <a class="link-arrow" href="<%= shop.phoneHref %>">Tap to call <span aria-hidden="true">&rarr;</span></a>
          </div>

          <div class="info-row">
            <p class="eyebrow">Hours</p>
            <ul class="hours-table">
              <% hours.forEach(function(h){ %>
                <li class="<%= h.days === todayLabel ? 'is-today' : '' %>">
                  <span><%= h.days %></span>
                  <span><%= h.time %></span>
                </li>
              <% }); %>
            </ul>
          </div>

          <div class="info-row">
            <p class="eyebrow">Follow</p>
            <p class="info-row__value info-row__value--md"><a href="<%= shop.instagram %>" rel="noopener">Instagram</a></p>
          </div>
        </div>

        <div class="contact-grid__map">
          <iframe
            title="Sulmina Barber Shop on a map"
            src="https://maps.google.com/maps?q=Sulmina+Barber+Shop,+43+High+St,+Southgate,+London+N14+6LD&z=17&output=embed"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            allowfullscreen></iframe>
        </div>

      </div>
    </div>
  </section>
</main>

<%- include('partials/footer') %>
