<!doctype html>
<html lang="en-GB">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
  <meta name="color-scheme" content="dark light">
  <meta name="theme-color" content="#fff6e6">
  <link rel="icon" href="/img/favicon.svg" type="image/svg+xml">

  <title><%= typeof title !== 'undefined' && title ? title : (typeof meta !== 'undefined' ? meta.title : 'Sulmina Barber Shop') %></title>
  <% if (typeof meta !== 'undefined' && meta.description) { %>
    <meta name="description" content="<%= meta.description %>">
  <% } %>
  <% if (typeof meta !== 'undefined' && meta.canonical) { %>
    <link rel="canonical" href="<%= meta.canonical %>">
  <% } %>
  <% if (typeof meta !== 'undefined' && meta.noindex) { %>
    <meta name="robots" content="noindex,follow">
  <% } %>

  <% if (typeof meta !== 'undefined') { %>
    <meta property="og:site_name" content="<%= meta.siteName %>">
    <meta property="og:title" content="<%= meta.title %>">
    <% if (meta.description) { %><meta property="og:description" content="<%= meta.description %>"><% } %>
    <% if (meta.canonical) { %><meta property="og:url" content="<%= meta.canonical %>"><% } %>
    <meta property="og:type" content="<%= meta.ogType || 'website' %>">
    <meta property="og:locale" content="en_GB">
    <% if (meta.ogImage) { %><meta property="og:image" content="<%= meta.ogImage %>"><% } %>

    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="<%= meta.title %>">
    <% if (meta.description) { %><meta name="twitter:description" content="<%= meta.description %>"><% } %>
  <% } %>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Anton&family=Fraunces:ital,opsz,wght@1,9..144,300..600&family=Manrope:wght@400;500;600;700;800&display=swap">
  <% const versionedAssetPath = typeof assetPath === 'function' ? assetPath : (asset) => asset; %>

  <link rel="preload" href="<%= versionedAssetPath('/css/base.css') %>" as="style">
  <link rel="preload" href="<%= versionedAssetPath('/css/layout.css') %>" as="style">

  <link rel="stylesheet" href="<%= versionedAssetPath('/css/base.css') %>">
  <link rel="stylesheet" href="<%= versionedAssetPath('/css/layout.css') %>">
  <link rel="stylesheet" href="<%= versionedAssetPath('/css/components.css') %>">
  <link rel="stylesheet" href="<%= versionedAssetPath('/css/booking.css') %>">
  <link rel="stylesheet" href="<%= versionedAssetPath('/css/reviews.css') %>">
  <link rel="stylesheet" href="<%= versionedAssetPath('/css/gallery.css') %>">

  <script src="<%= versionedAssetPath('/js/app.js') %>" defer></script>
  <script src="<%= versionedAssetPath('/js/booking-time.js') %>" defer></script>

  <% if (typeof loadElfsight !== 'undefined' && loadElfsight) { %>
    <script src="https://elfsightcdn.com/platform.js" async></script>
  <% } %>

  <% if (typeof jsonLd !== 'undefined' && jsonLd) { %>
    <% (Array.isArray(jsonLd) ? jsonLd : [jsonLd]).forEach(function(block){ %>
      <script type="application/ld+json"><%- JSON.stringify(block) %></script>
    <% }); %>
  <% } %>
</head>
<body>
  <a class="skip-link" href="#main">Skip to main content</a>
