<header class="site-header">
  <div class="site-header__inner">
    <a class="brand u-clean" href="/" aria-label="Sulmina — home">
      <%- include('logo', { uid: 'header' }) %>
      Sulmina
    </a>

    <nav class="site-nav" aria-label="Primary">
      <a href="/services" class="<%= currentPath === '/services' ? 'is-active' : '' %>">Services</a>
      <a href="/about"    class="<%= currentPath === '/about'    ? 'is-active' : '' %>">About</a>
      <a href="/gallery"  class="<%= currentPath === '/gallery'  ? 'is-active' : '' %>">Gallery</a>
      <a href="/contact"  class="<%= currentPath === '/contact'  ? 'is-active' : '' %>">Contact</a>
    </nav>

    <a class="btn btn--primary site-header__cta" href="/book">Book</a>

    <button class="menu-toggle" type="button" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-menu">
      <svg class="icon-open" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
        <path d="M4 7h16M4 12h16M4 17h16" stroke-linecap="round"/>
      </svg>
      <svg class="icon-close" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
        <path d="M6 6l12 12M6 18L18 6" stroke-linecap="round"/>
      </svg>
    </button>
  </div>
</header>

<div class="mobile-menu" id="mobile-menu" aria-hidden="true">

  <nav class="mobile-menu__nav" aria-label="Primary (mobile)">
    <a href="/services">Services</a>
    <a href="/about">About</a>
    <a href="/gallery">Gallery</a>
    <a href="/contact">Contact</a>
  </nav>

  <a class="mobile-menu__cta" href="/book">Book now →</a>

  <div class="mobile-menu__info">
    <div>
      <p class="mobile-menu__label">Call</p>
      <a class="mobile-menu__phone" href="<%= shop.phoneHref %>"><%= shop.phone %></a>
    </div>

    <div>
      <p class="mobile-menu__label">Hours</p>
      <ul class="hours-table">
        <% hours.forEach(function(h){ %>
          <li class="<%= typeof todayLabel !== 'undefined' && h.days === todayLabel ? 'is-today' : '' %>">
            <span><%= h.days %></span>
            <span><%= h.time %></span>
          </li>
        <% }); %>
      </ul>
    </div>

    <p class="mobile-menu__address"><%= shop.address %></p>
  </div>

</div>
