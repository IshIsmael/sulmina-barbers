<footer class="site-footer">
  <div class="container">
    <div class="site-footer__grid">

      <div class="site-footer__brand">
        <a href="/" class="brand u-clean" aria-label="Sulmina Barbershop — home">
          <img class="site-footer__logo" src="/img/logo.png"
               alt="Sulmina Barbershop" width="694" height="118" loading="lazy" decoding="async">
        </a>
        <p class="site-footer__tagline">
          Haircuts, fades and beard work at 43 High Street, Southgate.
        </p>
      </div>

      <nav class="site-footer__nav" aria-label="Footer">
        <p class="site-footer__head">Explore</p>
        <a href="/services">Services</a>
        <a href="/about">About</a>
        <a href="/gallery">Gallery</a>
        <a href="/contact">Contact</a>
        <a href="/book">Book a chair</a>
      </nav>

      <div>
        <p class="site-footer__head">Hours</p>
        <ul class="hours-table">
          <% hours.forEach(function(h){ %>
            <li class="<%= typeof todayLabel !== 'undefined' && h.days === todayLabel ? 'is-today' : '' %>">
              <span><%= h.days %></span>
              <span><%= h.time %></span>
            </li>
          <% }); %>
        </ul>
      </div>

      <div class="site-footer__social">
        <p class="site-footer__head">Visit</p>
        <p style="margin: 0 0 var(--s-3); color: color-mix(in oklab, var(--paper) 75%, transparent); font-size: 0.95rem;">
          43 High Street<br>London N14 6LD
        </p>
        <p style="margin: 0 0 var(--s-3);">
          <a class="u-clean" href="<%= shop.phoneHref %>" style="font-weight: 600;"><%= shop.phone %></a>
        </p>
        <p style="margin: 0;">
          <a class="link-arrow" href="<%= shop.instagram %>" rel="noopener">
            @sulmina_barbershop <span aria-hidden="true">→</span>
          </a>
        </p>
      </div>

    </div>
  </div>

  <p class="site-footer__giant" aria-hidden="true">Sulmina</p>

  <div class="site-footer__bottom">
    <div class="container">
      <div class="site-footer__legal">
        <span>© <%= new Date().getFullYear() %> <%= shop.name %></span>
        <span class="u-hide-mobile">·</span>
        <span>43 High Street, London N14 6LD</span>
      </div>
    </div>
  </div>
</footer>

</body>
</html>
