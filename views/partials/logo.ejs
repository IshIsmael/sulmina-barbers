<%
  /* Brand mark — barber-pole stripes inside a ring. Inherits text colour
     via currentColor so the same partial works on paper (header) and ink
     (footer). `uid` keeps clipPath ids unique when the mark appears more
     than once on a page. */
  var uid = typeof uid !== 'undefined' ? uid : 'm';
%>
<svg class="brand__mark" viewBox="0 0 32 32" aria-hidden="true" focusable="false">
  <defs>
    <clipPath id="brand-clip-<%= uid %>"><circle cx="16" cy="16" r="11.5"/></clipPath>
  </defs>
  <circle cx="16" cy="16" r="14.75" fill="none" stroke="currentColor" stroke-width="1.5"/>
  <g clip-path="url(#brand-clip-<%= uid %>)" style="stroke: var(--brass);" stroke-width="3.25">
    <line x1="-4" y1="20" x2="20" y2="-4"/>
    <line x1="4"  y1="28" x2="28" y2="4"/>
    <line x1="12" y1="36" x2="36" y2="12"/>
  </g>
</svg>
